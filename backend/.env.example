# Database Configuration
# For Atlas: Add 0.0.0.0/0 in Network Access to allow connections from any IP
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/virtual?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# Server Configuration
PORT=5001
HOST=0.0.0.0
NODE_ENV=development

# SMTP Email Configuration (Required for Password Reset)
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Password Reset Settings
RESET_EXPIRE_MINUTES=15

# Frontend URL (for email reset links)
FRONTEND_URL=http://localhost:3000

# For production use:
# - Set MONGODB_URI to your Atlas connection string
# - Generate a strong JWT_SECRET
# - Use production SMTP service (SendGrid, AWS SES, etc.)
# - Update FRONTEND_URL to your production domain
# - Keep all secrets secure (do NOT commit real values to repository)
